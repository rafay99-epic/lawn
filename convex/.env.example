# Convex DEPLOYMENT environment variables. Set these per deployment via the
# Convex dashboard (Settings -> Environment Variables) or `npx convex env set`.
# For local dev they are seeded from .env.local automatically
# (scripts/convex-local-setup.sh), so this file is mainly for cloud/prod.
# Note: client (VITE_*) and CONVEX_DEPLOYMENT vars live in the root .env, not here.

# clerk
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# payments feature flag
# Set to "false" to disable ALL Stripe/subscription enforcement (every team gets
# unlimited, always-active access). When "false", the stripe.* vars below are
# unused. Defaults to enabled if unset. Pair with VITE_PAYMENTS_ENABLED=false on
# the web/Vercel side to also hide the billing/pricing UI.
PAYMENTS_ENABLED=true

# stripe (only needed when PAYMENTS_ENABLED is not "false")
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# mux
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
MUX_SIGNING_KEY=
MUX_PRIVATE_KEY=

# storage (s3)
RAILWAY_ENDPOINT=
RAILWAY_ACCESS_KEY_ID=
RAILWAY_SECRET_ACCESS_KEY=
RAILWAY_REGION=us-east-1
RAILWAY_BUCKET_NAME=videos
RAILWAY_PUBLIC_URL=
RAILWAY_PUBLIC_URL_INCLUDE_BUCKET=

# autumn
AUTUMN_SECRET_KEY=

# chunkify
CHUNKIFY_PROJECT_ACCESS_TOKEN=
CHUNKIFY_WEBHOOK_SECRET=
