# Copy to .env.local and fill in. `bun run dev` provisions a local Convex
# deployment and seeds the secrets below into it (scripts/convex-local-setup.sh).
# Values marked "auto" are written/rewritten by `convex dev` — leave them blank.

# convex
CONVEX_DEPLOYMENT=                  # auto
VITE_CONVEX_URL=                    # auto
VITE_CONVEX_SITE_URL=              # auto

# clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# CLERK_JWT_ISSUER_DOMAIN is derived from the publishable key for local dev.

# payments feature flag
# Set BOTH to "false" to fully disable payments/billing (Stripe):
#   - PAYMENTS_ENABLED (Convex deployment var) removes all server enforcement.
#   - VITE_PAYMENTS_ENABLED (web build var) hides all billing/pricing UI.
# Defaults to enabled if unset. Local dev: PAYMENTS_ENABLED is NOT auto-seeded
# into Convex, so set it with `bunx convex env set PAYMENTS_ENABLED false`.
VITE_PAYMENTS_ENABLED=true
PAYMENTS_ENABLED=true

# stripe (only needed when PAYMENTS_ENABLED is not "false")
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_BASIC_MONTHLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx

# mux
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
MUX_SIGNING_KEY=
MUX_PRIVATE_KEY=                    # PEM; \n escapes are normalized

# storage (s3)
RAILWAY_ENDPOINT=
RAILWAY_ACCESS_KEY_ID=
RAILWAY_SECRET_ACCESS_KEY=
RAILWAY_REGION=us-east-1            # optional, default us-east-1
RAILWAY_BUCKET_NAME=videos         # optional, default videos
RAILWAY_PUBLIC_URL=                # optional, defaults to RAILWAY_ENDPOINT
RAILWAY_PUBLIC_URL_INCLUDE_BUCKET= # optional, set "false" to drop bucket from path

# autumn
AUTUMN_SECRET_KEY=

# chunkify
CHUNKIFY_PROJECT_ACCESS_TOKEN=
CHUNKIFY_WEBHOOK_SECRET=
